{
  "name": "black-stela",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "headless:reachability": "esbuild scripts/headless-clear.ts --bundle --platform=node --format=esm --loader:.md=text --outfile=.tmp/headless-clear.mjs --log-level=error && node .tmp/headless-clear.mjs",
    "headless:clear": "esbuild scripts/headless-clear.ts --bundle --platform=node --format=esm --loader:.md=text --outfile=.tmp/headless-clear.mjs --log-level=error && node .tmp/headless-clear.mjs",
    "headless:probes": "esbuild scripts/headless-probes.ts --bundle --platform=node --format=esm --loader:.md=text --outfile=.tmp/headless-probes.mjs --log-level=error && node .tmp/headless-probes.mjs",
    "headless:combat": "esbuild scripts/combat-probes.ts --bundle --platform=node --format=esm --loader:.md=text --outfile=.tmp/combat-probes.mjs --log-level=error && node .tmp/combat-probes.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
