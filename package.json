{
  "name": "black-stela",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "selfplay:browser": "playwright test tests/e2e/selfplay.spec.ts --workers=1",
    "gate:final": "FINAL_GATE=1 playwright test",
    "headless:reachability": "node scripts/run-vite-module.mjs scripts/headless-clear.ts",
    "headless:clear": "node scripts/run-vite-module.mjs scripts/headless-clear.ts",
    "headless:probes": "node scripts/run-vite-module.mjs scripts/headless-probes.ts",
    "headless:combat": "node scripts/run-vite-module.mjs scripts/combat-probes.ts",
    "sim:content": "node scripts/run-vite-module.mjs scripts/content-sim.ts",
    "export:packs": "node scripts/run-vite-module.mjs scripts/export-packs.ts",
    "export:traces": "node scripts/run-vite-module.mjs scripts/export-traces.ts",
    "export:rng": "node scripts/run-vite-module.mjs scripts/export-rng-samples.ts",
    "export:godot": "npm run export:packs && npm run export:traces && npm run export:rng",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
